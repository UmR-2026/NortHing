        "IdeControl" => "\u{2318}",                       // ⌘
        "MermaidInteractive" => "\u{25c7}",               // ◇
        "ContextCompression" => "\u{21af}",               // ↯
        "AnalyzeImage" => "\u{25a3}",                     // ▣
        _ if tool_name.starts_with("mcp_") => "\u{2261}", // ≡
        _ => "\u{00b7}",                                  // ·
    }
}


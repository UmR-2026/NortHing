ASSETS_LICENSES.md

external/

# Windows reserved device name - PowerShell/cmd redirection side-effect
# git status may report a 0-byte phantom file matching this name
nul

# Hermes Agent session artifacts
.mavis/

# CodeGraph — pre-indexed code knowledge graph for AI agents (colbymchenry/codegraph).
# 120 MB SQLite cache; per-machine, never commit. The nested .codegraph/.gitignore
# already ignores *contents*; the root entry skips the directory itself so `git
# status` doesn't list it as untracked.
.codegraph/

# codebase-memory-mcp — shared target directory (via .cargo/config.toml target-dir)
target-shared/

# Local cargo target directory for isolated verification
target-local/

# Ad-hoc code-rot scan artifacts (temporary investigation scripts/reports)
_rot_scan*

# Development scripts — never commit
# NOTE: These patterns are ROOT-ONLY (leading /) so they don't accidentally
# ignore .py/.cjs in subdirectories like northing-installer/src/.
/*.py
/*.cjs

# Audit scratch files (root-only)
/r60c-*
/r63a-*

# Phantom file pattern (PowerShell redirection side-effect, root-only)
/{}

# VERSIONS_DIR placeholder
VERSIONS_DIR=.

# .graph FTS5 + vector databases (regenerated from memory/)
/.graph/*.db

# Local credentials (never commit)
/memory/credentials.md


    out property <string> identity-prompt-q5: "还有什么需要我记住的？";
    out property <string> identity-regenerate: "重新生成";
    out property <string> identity-save: "保存到工作文件夹";
    out property <string> identity-back: "上一步";
    out property <string> identity-llm-failed: "LLM 调用失败：{error}（可手动编辑后保存）";

    // ===== First-run banner (Q1=a 旧用户检测) =====
    out property <string> first-run-legacy-banner-title: "检测到已废弃 AI 服务占位";
    out property <string> first-run-legacy-banner-body: "你的 app.json 里有 P0-B 阶段 seed 的 {n} 个 disabled 占位。点击清理按钮删除它们。";

    // ===== Generic =====
    out property <string> yes: "是";
    out property <string> no: "否";
    out property <string> cancel: "取消";
    out property <string> confirm: "确认";
    out property <string> save: "保存";
    out property <string> close: "关闭";
    out property <string> loading: "加载中…";
}
    out property <string> mcp-empty: "还没有添加工具集";
    out property <string> mcp-remove-confirm: "移除工具集？";

    // ===== Error banner + inline (Q8=c 双通道) =====
    out property <string> error-detail-button: "详情";
    out property <string> error-dismiss: "关闭";
    out property <string> error-save-failed: "保存失败：{error}（变更未持久化）";
